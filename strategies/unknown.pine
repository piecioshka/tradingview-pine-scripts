// The techniques I use are trailing with real-time price and EMA11, 21, 200.
// https://www.patreon.com/donaldit/shop/spx-15-options-trading-strategy-321411

//@version=6
strategy('PK - EMA trailing (11/21/200)', overlay=true, fill_orders_on_standard_ohlc=true, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.01)

// Inputs
lenFast   = input.int(11,  'EMA fast (11)')
lenSlow   = input.int(21,  'EMA slow (21)')
lenTrend  = input.int(200, 'EMA trend (200)')
useAtrBuf = input.bool(true, 'Use ATR buffer')
atrLen    = input.int(14, 'ATR length')
atrMult   = input.float(1.0, 'ATR multiplier', minval=0.0)
trailMode = input.string('EMA21', 'Trailing source', options=['EMA11', 'EMA21', 'EMA200'])

// EMAs
ema11  = ta.ema(close, lenFast)
ema21  = ta.ema(close, lenSlow)
ema200 = ta.ema(close, lenTrend)

// Entry logic: crossover 11 over 21, with filter that both are above 200
longCross        = ta.crossover(ema11, ema21)
above200Filter   = ema11 > ema200 and ema21 > ema200
longCondition    = longCross and above200Filter

// Optional exit logic: crossunder 11 below 21 or losing trend filter
exitOnCrossDown  = ta.crossunder(ema11, ema21)
loseTrendFilter  = ema21 < ema200

// Trailing source selection
trailSrc = trailMode == 'EMA11' ? ema11 : trailMode == 'EMA21' ? ema21 : ema200

// ATR buffer (to avoid too tight trailing)
atr = ta.atr(atrLen)
buffer = useAtrBuf ? atr * atrMult : 0.0

// Define trailing stop price (for long)
trailStopLong = trailSrc - buffer

// Entry
if (longCondition and strategy.position_size <= 0)
    strategy.entry('Long EMA11/21 over 200', strategy.long)

// Manage trailing: move stop up only when price advances; never lower it (classic trailing)
var float highestTrailStop = na
highestTrailStop := na(highestTrailStop) ? trailStopLong : math.max(highestTrailStop, trailStopLong)

// Reset trailing tracker on flat
if (strategy.position_size <= 0)
    highestTrailStop := na

// Exit conditions:
// 1) Protective trailing stop based on chosen EMA minus ATR buffer
// 2) Immediate exit if 11 crosses below 21 or trend filter is lost
exitNow = exitOnCrossDown or loseTrendFilter

// Place exits. We use both: a stop at highestTrailStop and a market exit on exitNow.
if (strategy.position_size > 0)
    // Update stop
    strategy.exit('Trail', from_entry='Long EMA11/21 over 200', stop=highestTrailStop)
    // Optional hard exit on signals
    if (exitNow)
        strategy.close('Long EMA11/21 over 200')

// Debug/plots
plot(ema11,  title='EMA(11)',  color=color.new(color.green, 0))
plot(ema21,  title='EMA(21)',  color=color.new(color.blue,  0))
plot(ema200, title='EMA(200)', color=color.new(color.orange,0))

plot(trailSrc,       title='Trailing Source', color=color.new(color.purple, 0))
plot(highestTrailStop, title='Trailing Stop', color=color.new(color.red, 0), style=plot.style_linebr)
