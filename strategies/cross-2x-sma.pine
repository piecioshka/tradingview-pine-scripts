//@version=6
strategy("😎 Strategy (by PK)", overlay=true, fill_orders_on_standard_ohlc = true)

a = input(50, 'Krótki okres SMA')
b = input(200, 'Długi okres SMA')

aSMA = ta.sma(close, a)
bSMA = ta.sma(close, b)

longCondition = ta.crossover(aSMA, bSMA)
if (longCondition)
    strategy.entry("My Long Entry Id", strategy.long)

shortCondition = ta.crossunder(aSMA, bSMA)
if (shortCondition)
    strategy.entry("My Short Entry Id", strategy.short)
