//@version=6
strategy('Strategy', overlay=true, fill_orders_on_standard_ohlc = true)

aLen = input(50, 'Krótki okres SMA')
bLen = input(200, 'Długi okres SMA')

aSeries = ta.sma(close, aLen)
bSeries = ta.sma(close, bLen)

plot(aSeries, 'SMA krótka', color=color.aqua, linewidth=2)
plot(bSeries, 'SMA długa', color=color.orange, linewidth=2)

if (ta.crossover(aSeries, bSeries))
    strategy.entry('My Long Entry Id', strategy.long)

if (ta.crossunder(aSeries, bSeries))
    strategy.entry('My Short Entry Id', strategy.short)
