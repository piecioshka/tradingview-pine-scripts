//@version=6
indicator('Delta Footprint Imbalance', shorttitle='Delta FP Imbalance', overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// Imbalans footprintu (diagonal / stacked) z prawdziwych danych request.footprint (od stycznia 2026).
// Footprint dzieli świecę na poziomy cenowe i zna wolumen agresorów po stronie kupna (ask) i sprzedaży (bid).
//
// IMBALANS DIAGONALNY (porównanie „po przekątnej", jak w klasycznym footprincie):
//   • Kupna (ask):     wolumen KUPNA na poziomie P  vs  wolumen SPRZEDAŻY o jeden poziom NIŻEJ (P-1).
//   • Sprzedaży (bid): wolumen SPRZEDAŻY na poziomie P  vs  wolumen KUPNA o jeden poziom WYŻEJ (P+1).
//   Imbalans, gdy strona dominująca ≥ (mnożnik) × strona przeciwna (klasycznie 3:1).
//
// IMBALANS UŁOŻONY (stacked): N+ kolejnych poziomów z imbalansem w tym samym kierunku (domyślnie 3).
//   Ułożone imbalansy kupna  = strefa agresywnej akumulacji / potencjalne WSPARCIE (zielona).
//   Ułożone imbalansy sprzedaży = strefa agresywnej dystrybucji / potencjalny OPÓR (czerwona).
//
// STREFY (główna wartość): każdy ułożony imbalans staje się strefą S/R rysowaną jako box ciągnący się
//   w prawo, DOPÓKI cena jej nie przetestuje (mitygacja). Po przetestowaniu strefa blednie lub znika.
//   Siła strefy (liczba ułożonych poziomów) steruje jej intensywnością koloru. Mini-dashboard liczy
//   aktywne strefy i wskazuje najbliższą nad/pod ceną.
//
// WYMAGANIA / OGRANICZENIA (narzucone przez TradingView):
//   • Konto Premium lub Ultimate — bez tego skrypt się NIE skompiluje.
//   • request.footprint() działa tylko dla BIEŻĄCEGO interwału, jedno wywołanie na skrypt.
//   • Strefy powstają tylko na ZAMKNIĘTYCH świecach (brak repaintu) — świeca w budowie czeka na zamknięcie.

// --- Paleta domyślna (kolory świec TradingView) ---
cBuyDef  = color.rgb(38, 166, 154)  // imbalans kupna — domyślna zieleń świecy #26A69A
cSellDef = color.rgb(239, 83, 80)   // imbalans sprzedaży — domyślna czerwień świecy #EF5350

// --- Strefa ułożonego imbalansu (S/R) ---
type Zone
    float top         // górna granica strefy (cena)
    float bot         // dolna granica strefy (cena)
    int   dir         // 1 = kupna (byk), -1 = sprzedaży (niedźwiedź)
    int   strength    // liczba ułożonych poziomów (siła)
    int   startBar    // bar_index powstania
    bool  armed       // czy cena opuściła strefę (uzbrojenie testu mitygacji)
    bool  mitigated   // czy strefa została przetestowana
    box   bx
    label lb

// --- Footprint ---
gCalc = 'Footprint'
ticksPerRow = input.int(5, 'Ticki na wiersz', minval=1, group=gCalc, tooltip='Wysokość wiersza footprintu w tickach = rozdzielczość poziomów imbalansu. Mniej = drobniejsze poziomy (czulszy imbalans), ale więcej obliczeń.')

// --- Imbalans ---
gImb = 'Imbalans'
ratio    = input.float(3.0, 'Mnożnik imbalansu (X:1)', minval=1.0, step=0.1, group=gImb, tooltip='Strona dominująca musi być ≥ X razy większa od przeciwnej (po przekątnej). Klasycznie 3:1.')
minVol   = input.float(0.0, 'Min. wolumen poziomu',    minval=0.0, group=gImb, tooltip='Ignoruj poziomy, na których wolumen strony dominującej jest poniżej tej wartości (filtr szumu). 0 = bez filtra.')
minStack = input.int(3, 'Min. ułożonych poziomów (stacked)', minval=2, group=gImb, tooltip='Ile kolejnych poziomów z imbalansem w tym samym kierunku tworzy strefę.')

// --- Strefy S/R ---
gZones = 'Strefy S/R'
showZones   = input.bool(true,  'Pokaż strefy ułożone',           group=gZones, tooltip='Każdy ułożony imbalans = strefa ciągnąca się w prawo, aż cena ją przetestuje.')
mitUseClose = input.bool(true, 'Mitygacja wg zamknięcia',        group=gZones, tooltip='Strefa „przetestowana", gdy ZAMKNIĘCIE wejdzie w strefę. Wyłączone = liczy się knot (high/low) — czulsze.')
hideMitig   = input.bool(true, 'Ukryj strefy po teście',         group=gZones, tooltip='Usuń strefę zaraz po przetestowaniu. Wyłączone = strefa zostaje, ale blednie (linia przerywana).')
tMitig      = input.int(92, 'Przezroczystość po teście', minval=0, maxval=100, group=gZones, tooltip='Jak bardzo zblednąć strefę po przetestowaniu (gdy nie jest ukrywana).')
maxZones    = input.int(25, 'Maks. liczba stref', minval=1, maxval=200, group=gZones, tooltip='Trzymaj tylko N ostatnich stref (starsze są usuwane). Chroni przed limitem obiektów wykresu.')

// --- Siła w kolorze ---
gStr = 'Siła w kolorze'
tZoneWeak   = input.int(85, 'Przezroczystość — słaba strefa', minval=0, maxval=100, group=gStr, tooltip='Przezroczystość strefy o długości = „Min. ułożonych poziomów" (najsłabsza).')
tZoneStrong = input.int(35, 'Przezroczystość — mocna strefa', minval=0, maxval=100, group=gStr, tooltip='Przezroczystość strefy o długości „Min. + 6" lub większej (najmocniejsza). Mniej = bardziej krzykliwa.')

// --- Wyświetlanie ---
gView = 'Wyświetlanie'
showCount  = input.bool(true,  'Liczba poziomów w strefie', group=gView, tooltip='Etykieta z liczbą ułożonych poziomów (siłą) przy strefie.')
showLevels = input.bool(false, 'Pokaż pojedyncze imbalansy', group=gView, tooltip='Marka na KAŻDYM poziomie z imbalansem (pionowa kreska w osi świecy). Domyślnie wyłączone.')
markWidth  = input.int(6, 'Grubość pojedynczych marek (px)', minval=1, maxval=30, group=gView, tooltip='Grubość pionowej marki pojedynczego imbalansu (w pikselach), wyśrodkowanej na świecy.')
tLevels    = input.int(80, 'Przezroczystość pojedynczych', minval=0, maxval=100, group=gView)

// --- Mini-dashboard ---
gDash = 'Mini-dashboard'
showDash = input.bool(true, 'Pokaż dashboard', group=gDash, tooltip='Tabelka: liczba aktywnych stref byczych/niedźwiedzich + najbliższa strefa nad i pod ceną.')
dashPos  = input.string('Prawy dolny', 'Pozycja', options=['Lewy górny', 'Prawy górny', 'Lewy dolny', 'Prawy dolny'], group=gDash)

// --- Kolory ---
gColors = 'Kolory'
cBuy  = input.color(cBuyDef,  'Imbalans kupna (ask)',     group=gColors)
cSell = input.color(cSellDef, 'Imbalans sprzedaży (bid)', group=gColors)

// --- Footprint bieżącej świecy ---
fp = request.footprint(ticksPerRow)
hasData = not na(fp)

// Stan: aktywne i przetestowane strefy.
var array<Zone> zones = array.new<Zone>()

// Flagi alertów (ustawiane w pętli, czytane przez alertcondition w zakresie globalnym).
bool stackBuy  = false
bool stackSell = false

// Przezroczystość wg siły strefy: minStack → słaba, minStack+6 → mocna.
f_zoneTransp(int s) =>
    f = math.min(1.0, math.max(0.0, (s - minStack) / 6.0))
    int(tZoneWeak + (tZoneStrong - tZoneWeak) * f)

if hasData and barstate.isconfirmed
    rows = fp.rows()
    n = array.size(rows)
    if n >= 2
        // --- Odczyt poziomów do tablic ---
        buyV  = array.new<float>()
        sellV = array.new<float>()
        pUp   = array.new<float>()
        pDn   = array.new<float>()
        for i = 0 to n - 1
            r = array.get(rows, i)
            array.push(buyV,  r.buy_volume())
            array.push(sellV, r.sell_volume())
            array.push(pUp,   r.up_price())
            array.push(pDn,   r.down_price())

        // Uporządkuj rosnąco po cenie (indeks 0 = najniższy poziom), niezależnie od kolejności API.
        if array.get(pDn, 0) > array.get(pDn, n - 1)
            array.reverse(buyV)
            array.reverse(sellV)
            array.reverse(pUp)
            array.reverse(pDn)

        // --- Kierunek imbalansu na każdym poziomie: 1 = kupna, -1 = sprzedaży, 0 = brak ---
        dir = array.new<int>(n, 0)
        for i = 0 to n - 1
            bv = array.get(buyV, i)
            sv = array.get(sellV, i)
            buyImb = false
            if i >= 1
                bvAgainst = array.get(sellV, i - 1)   // sprzedaż o jeden poziom NIŻEJ (przekątna)
                buyImb := bv > 0 and bv >= minVol and bv >= ratio * bvAgainst
            sellImb = false
            if i <= n - 2
                svAgainst = array.get(buyV, i + 1)    // kupno o jeden poziom WYŻEJ (przekątna)
                sellImb := sv > 0 and sv >= minVol and sv >= ratio * svAgainst
            d = 0
            if buyImb and sellImb
                d := bv >= sv ? 1 : -1                // rzadki remis — wybierz silniejszą stronę
            else if buyImb
                d := 1
            else if sellImb
                d := -1
            array.set(dir, i, d)

        // --- Pojedyncze poziomy z imbalansem (pionowa marka w osi świecy) ---
        if showLevels
            for i = 0 to n - 1
                d = array.get(dir, i)
                if d != 0
                    col = d == 1 ? cBuy : cSell
                    line.new(bar_index, array.get(pUp, i), bar_index, array.get(pDn, i), xloc=xloc.bar_index, color=color.new(col, tLevels), width=markWidth)

        // --- Strefy ułożone: maksymalne ciągi tego samego kierunku ≥ minStack ---
        i = 0
        while i < n
            d = array.get(dir, i)
            if d != 0
                j = i
                while j + 1 < n and array.get(dir, j + 1) == d
                    j += 1
                runLen = j - i + 1
                if runLen >= minStack
                    if d == 1
                        stackBuy := true
                    else
                        stackSell := true
                    if showZones
                        topP = array.get(pUp, j)      // górna cena najwyższego poziomu w ciągu
                        botP = array.get(pDn, i)      // dolna cena najniższego poziomu w ciągu
                        // Pomiń, jeśli aktywna strefa tego samego kierunku już pokrywa ten zakres cen.
                        // (while zamiast for — „for 0 to size-1" przy pustej tablicy daje 0..-1 i sięga po indeks 0)
                        overlaps = false
                        zi = 0
                        while zi < array.size(zones)
                            z = array.get(zones, zi)
                            if not z.mitigated and z.dir == d and topP >= z.bot and botP <= z.top
                                overlaps := true
                            zi += 1
                        if not overlaps
                            col   = d == 1 ? cBuy : cSell
                            transp = f_zoneTransp(runLen)
                            bx = box.new(bar_index, topP, bar_index, botP, xloc=xloc.bar_index, border_color=color.new(col, 25), border_width=1, bgcolor=color.new(col, transp))
                            label lb = na
                            if showCount
                                lb := label.new(bar_index, d == 1 ? botP : topP, str.tostring(runLen), xloc=xloc.bar_index, yloc=yloc.price, style=d == 1 ? label.style_label_up : label.style_label_down, color=color.new(col, 20), textcolor=color.white, size=size.small)
                            array.push(zones, Zone.new(topP, botP, d, runLen, bar_index, false, false, bx, lb))
                i := j + 1
            else
                i += 1

        // --- Limit liczby stref: usuń najstarsze ponad maxZones ---
        while array.size(zones) > maxZones
            z0 = array.shift(zones)
            box.delete(z0.bx)
            if not na(z0.lb)
                label.delete(z0.lb)

// --- Utrzymanie stref co zamkniętą świecę: mitygacja + przedłużanie w prawo ---
if barstate.isconfirmed
    mtLow  = mitUseClose ? close : low
    mtHigh = mitUseClose ? close : high
    k = 0
    while k < array.size(zones)
        z = array.get(zones, k)
        keep = true
        if not z.mitigated
            // Uzbrój test, gdy cena opuści strefę; mityguj, gdy do niej wróci.
            if bar_index > z.startBar
                if not z.armed and ((z.dir == 1 and low > z.top) or (z.dir == -1 and high < z.bot))
                    z.armed := true
                if z.armed and ((z.dir == 1 and mtLow <= z.top) or (z.dir == -1 and mtHigh >= z.bot))
                    z.mitigated := true
            box.set_right(z.bx, bar_index)   // przedłuż do teraz (albo zamroź na świecy mitygacji)
            if z.mitigated
                if hideMitig
                    box.delete(z.bx)
                    if not na(z.lb)
                        label.delete(z.lb)
                    array.remove(zones, k)
                    keep := false
                else
                    col = z.dir == 1 ? cBuy : cSell
                    box.set_bgcolor(z.bx, color.new(col, tMitig))
                    box.set_border_style(z.bx, line.style_dashed)
        if keep
            k += 1

// --- Mini-dashboard (liczba aktywnych stref + najbliższa nad/pod ceną) ---
var table dash = table.new(position.top_left, 2, 4, border_width=1, border_color=color.new(color.gray, 70))
if showDash and barstate.islast
    int   actBull = 0
    int   actBear = 0
    float nearAbove = na
    float nearBelow = na
    int   dirAbove = 0
    int   dirBelow = 0
    if array.size(zones) > 0
        for idx = 0 to array.size(zones) - 1
            z = array.get(zones, idx)
            if not z.mitigated
                if z.dir == 1
                    actBull += 1
                else
                    actBear += 1
                if z.bot > close and (na(nearAbove) or z.bot - close < nearAbove - close)
                    nearAbove := z.bot
                    dirAbove  := z.dir
                if z.top < close and (na(nearBelow) or close - z.top < close - nearBelow)
                    nearBelow := z.top
                    dirBelow  := z.dir
    dpos = dashPos == 'Lewy górny' ? position.top_left : dashPos == 'Prawy górny' ? position.top_right : dashPos == 'Lewy dolny' ? position.bottom_left : position.bottom_right
    table.set_position(dash, dpos)
    table.clear(dash, 0, 0, 1, 3)
    table.cell(dash, 0, 0, 'Strefy ▲ byk',  text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 0, str.tostring(actBull), text_color=cBuy, text_size=size.small)
    table.cell(dash, 0, 1, 'Strefy ▼ niedźw.', text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(actBear), text_color=cSell, text_size=size.small)
    aboveTxt = na(nearAbove) ? '—' : str.tostring(nearAbove, format.mintick) + '  (+' + str.tostring(nearAbove - close, format.mintick) + ')'
    belowTxt = na(nearBelow) ? '—' : str.tostring(nearBelow, format.mintick) + '  (-' + str.tostring(close - nearBelow, format.mintick) + ')'
    table.cell(dash, 0, 2, 'Najbliższa nad', text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 2, aboveTxt, text_color=na(nearAbove) ? color.gray : (dirAbove == 1 ? cBuy : cSell), text_size=size.small)
    table.cell(dash, 0, 3, 'Najbliższa pod', text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 3, belowTxt, text_color=na(nearBelow) ? color.gray : (dirBelow == 1 ? cBuy : cSell), text_size=size.small)

// --- Alerty (formowanie ułożonego imbalansu) ---
alertcondition(stackBuy,  'Ułożony imbalans kupna',     'Nowa strefa ułożonego imbalansu kupna (akumulacja / wsparcie)')
alertcondition(stackSell, 'Ułożony imbalans sprzedaży', 'Nowa strefa ułożonego imbalansu sprzedaży (dystrybucja / opór)')
