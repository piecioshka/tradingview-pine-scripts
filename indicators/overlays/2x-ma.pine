//@version=6
indicator('📈 2x MA = Moving Average (by PK)', shorttitle='2x MA', overlay = true)

aLen = input(50, 'Długość', group='Krótki')
aType = input.string(title='Typ', options=['SMA', 'EMA', 'WMA', 'VWMA', 'RMA'], group='Krótki', defval='SMA')
aColor = input.color(color.rgb(56, 104, 174), 'Kolor', group='Krótki')
aSeries = switch aType
    'SMA' => ta.sma(close, aLen)
    'EMA' => ta.ema(close, aLen)
    'WMA' => ta.wma(close, aLen)
    'VWMA' => ta.vwma(close, aLen)
    'RMA' => ta.rma(close, aLen)
    => na

bLen = input(200, 'Długość', group='Długi')
bType = input.string(title='Typ', options=['SMA', 'EMA', 'WMA', 'VWMA', 'RMA'], group='Długi', defval='SMA')
bColor = input.color(color.rgb(215, 107, 52), 'Kolor', group='Długi')
bSeries = switch bType
    'SMA' => ta.sma(close, bLen)
    'EMA' => ta.ema(close, bLen)
    'WMA' => ta.wma(close, bLen)
    'VWMA' => ta.vwma(close, bLen)
    'RMA' => ta.rma(close, bLen)
    => na

showLabels = input.bool(false, 'Pokaż etykiety (długość i typ)', group='Etykiety')

plot(aSeries, 'Krótki', color=color.new(aColor, 30), linewidth=2, force_overlay=true)
plot(bSeries, 'Długi', color=color.new(bColor, 30), linewidth=2, force_overlay=true, linestyle=plot.linestyle_dotted)

updateLabel(label lbl, float y, string txt, color col) =>
    label result = lbl
    if na(result)
        result := label.new(bar_index, y, txt, style=label.style_label_left, color=color.new(color.black, 100), textcolor=col, force_overlay=true)
    label.set_xy(result, bar_index, y)
    label.set_text(result, txt)
    result

var label aLabel = na
var label bLabel = na

if showLabels and barstate.islast
    aLabel := updateLabel(aLabel, aSeries, str.tostring(aLen) + ' ' + aType, aColor)
    bLabel := updateLabel(bLabel, bSeries, str.tostring(bLen) + ' ' + bType, bColor)

if (ta.crossover(aSeries, bSeries))
    label.new(bar_index, aSeries, 'BUY OPEN', color=color.new(color.green, 50), style=label.style_label_up, size=size.normal, force_overlay=true)

if (ta.crossunder(aSeries, bSeries))
    label.new(bar_index, aSeries, 'BUY CLOSE', color=color.new(color.red, 50), style=label.style_label_down, size=size.normal, force_overlay=true)
