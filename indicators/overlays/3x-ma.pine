//@version=6
indicator('3x MA = Moving Average (by PK)', shorttitle='3x MA', overlay = true)

aLen = input(4, 'Długość', group='Krótki')
aType = input.string(title='Typ', options=['SMA', 'EMA', 'WMA', 'VWMA', 'RMA'], group='Krótki', defval='SMA')
aColor = input.color(color.rgb(237, 197, 57), 'Kolor', group='Krótki')
aSeries = switch aType
    'SMA' => ta.sma(close, aLen)
    'EMA' => ta.ema(close, aLen)
    'WMA' => ta.wma(close, aLen)
    'VWMA' => ta.vwma(close, aLen)
    'RMA' => ta.rma(close, aLen)
    => na

bLen = input(9, 'Długość', group='Średni')
bType = input.string(title='Typ', options=['SMA', 'EMA', 'WMA', 'VWMA', 'RMA'], group='Średni', defval='SMA')
bColor = input.color(color.rgb(141, 68, 57), 'Kolor', group='Średni')
bSeries = switch bType
    'SMA' => ta.sma(close, bLen)
    'EMA' => ta.ema(close, bLen)
    'WMA' => ta.wma(close, bLen)
    'VWMA' => ta.vwma(close, bLen)
    'RMA' => ta.rma(close, bLen)
    => na

cLen = input(18, 'Długość', group='Długi')
cType = input.string(title='Typ', options=['SMA', 'EMA', 'WMA', 'VWMA', 'RMA'], group='Długi', defval='SMA')
cColor = input.color(color.rgb(194, 59, 47), 'Kolor', group='Długi')
cSeries = switch cType
    'SMA' => ta.sma(close, cLen)
    'EMA' => ta.ema(close, cLen)
    'WMA' => ta.wma(close, cLen)
    'VWMA' => ta.vwma(close, cLen)
    'RMA' => ta.rma(close, cLen)
    => na

showLabels = input.bool(true, 'Pokaż etykiety (długość i typ)', group='Etykiety')

plot(aSeries, 'Krótki', color=color.new(aColor, 0), linewidth=2, force_overlay=true)
plot(bSeries, 'Średni', color=color.new(bColor, 0), linewidth=2, force_overlay=true)
plot(cSeries, 'Długi', color=color.new(cColor, 0), linewidth=2, force_overlay=true)

updateLabel(label lbl, float y, string txt, color col) =>
    label result = lbl
    if na(result)
        result := label.new(bar_index, y, txt, style=label.style_label_left, color=color.new(color.black, 100), textcolor=col, force_overlay=true)
    label.set_xy(result, bar_index, y)
    label.set_text(result, txt)
    result

var label aLabel = na
var label bLabel = na
var label cLabel = na

if showLabels and barstate.islast
    aLabel := updateLabel(aLabel, aSeries, str.tostring(aLen) + ' ' + aType, aColor)
    bLabel := updateLabel(bLabel, bSeries, str.tostring(bLen) + ' ' + bType, bColor)
    cLabel := updateLabel(cLabel, cSeries, str.tostring(cLen) + ' ' + cType, cColor)
