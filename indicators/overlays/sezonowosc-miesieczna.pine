//@version=6
indicator('🗓️ Sezonowość miesięczna (by PK)', shorttitle='Sezonowość M', overlay = true)

// Wskaźnik koloruje tło wykresu różnymi kolorami w zależności od miesiąca.
// Zaprojektowany dla interwału miesięcznego (1M) - każda świeca = jeden miesiąc.
// Kolory układają się w gradient przez koło barw HSV (zima → wiosna → lato → jesień → zima),
// dzięki czemu łatwo zauważyć powtarzające się układy sezonowe (np. Lean Hogs).

transp = input.int(title='Przezroczystość (0-100)', defval=80, minval=0, maxval=100, step=5)
showLegend = input.bool(title='Pokaż legendę', defval=true)
legendPosition = input.string(title='Pozycja legendy', defval='Prawy górny', options=['Lewy górny', 'Prawy górny', 'Lewy dolny', 'Prawy dolny'])

// Włączanie/wyłączanie poszczególnych miesięcy.
// Przydatne dla kontraktów, które nie są dostępne we wszystkich miesiącach
// (np. Lean Hogs / HE - tylko 8 miesięcy: G, J, K, M, N, Q, V, Z).
gMonths = 'Miesiące'
useJan = input.bool(title='Styczeń (F)',     defval=true, group=gMonths)
useFeb = input.bool(title='Luty (G)',        defval=true, group=gMonths)
useMar = input.bool(title='Marzec (H)',      defval=true, group=gMonths)
useApr = input.bool(title='Kwiecień (J)',    defval=true, group=gMonths)
useMay = input.bool(title='Maj (K)',         defval=true, group=gMonths)
useJun = input.bool(title='Czerwiec (M)',    defval=true, group=gMonths)
useJul = input.bool(title='Lipiec (N)',      defval=true, group=gMonths)
useAug = input.bool(title='Sierpień (Q)',    defval=true, group=gMonths)
useSep = input.bool(title='Wrzesień (U)',    defval=true, group=gMonths)
useOct = input.bool(title='Październik (V)', defval=true, group=gMonths)
useNov = input.bool(title='Listopad (X)',    defval=true, group=gMonths)
useDec = input.bool(title='Grudzień (Z)',    defval=true, group=gMonths)

// 12 kolorów - gradient przez koło barw HSV
colJan = color.rgb(30, 60, 200)     // styczeń - granat (głęboka zima)
colFeb = color.rgb(0, 140, 220)     // luty - błękit
colMar = color.rgb(0, 180, 170)     // marzec - turkus (przedwiośnie)
colApr = color.rgb(60, 180, 60)     // kwiecień - zieleń (wiosna)
colMay = color.rgb(160, 200, 50)    // maj - limonka
colJun = color.rgb(230, 220, 0)     // czerwiec - żółć (początek lata)
colJul = color.rgb(240, 160, 0)     // lipiec - pomarańcz (pełnia lata)
colAug = color.rgb(230, 100, 30)    // sierpień - czerwono-pomarańczowy
colSep = color.rgb(220, 50, 50)     // wrzesień - czerwień (jesień)
colOct = color.rgb(200, 50, 140)    // październik - magenta
colNov = color.rgb(160, 60, 190)    // listopad - fiolet
colDec = color.rgb(90, 60, 200)     // grudzień - ciemny fiolet (powrót do zimy)

m = month(time)

bgCol = switch m
    1  => useJan ? color.new(colJan, transp) : na
    2  => useFeb ? color.new(colFeb, transp) : na
    3  => useMar ? color.new(colMar, transp) : na
    4  => useApr ? color.new(colApr, transp) : na
    5  => useMay ? color.new(colMay, transp) : na
    6  => useJun ? color.new(colJun, transp) : na
    7  => useJul ? color.new(colJul, transp) : na
    8  => useAug ? color.new(colAug, transp) : na
    9  => useSep ? color.new(colSep, transp) : na
    10 => useOct ? color.new(colOct, transp) : na
    11 => useNov ? color.new(colNov, transp) : na
    12 => useDec ? color.new(colDec, transp) : na
    => na

bgcolor(bgCol)

// Legenda - tabelka pokazująca które miesiące mają jaki kolor
if showLegend and barstate.islast
    pos = switch legendPosition
        'Lewy górny'  => position.top_left
        'Prawy górny' => position.top_right
        'Lewy dolny'  => position.bottom_left
        'Prawy dolny' => position.bottom_right
        =>               position.top_right

    months = array.from('Styczeń', 'Luty', 'Marzec', 'Kwiecień', 'Maj', 'Czerwiec', 'Lipiec', 'Sierpień', 'Wrzesień', 'Październik', 'Listopad', 'Grudzień')
    colors = array.from(colJan, colFeb, colMar, colApr, colMay, colJun, colJul, colAug, colSep, colOct, colNov, colDec)
    enabled = array.from(useJan, useFeb, useMar, useApr, useMay, useJun, useJul, useAug, useSep, useOct, useNov, useDec)

    activeCount = 0
    for i = 0 to 11
        if array.get(enabled, i)
            activeCount += 1

    if activeCount > 0
        legend = table.new(position = pos, columns = 2, rows = activeCount, border_width = 1)
        row = 0
        for i = 0 to 11
            if array.get(enabled, i)
                table.cell(legend, 0, row, '    ', bgcolor = array.get(colors, i))
                table.cell(legend, 1, row, array.get(months, i), text_color = color.white, bgcolor = color.new(color.black, 30))
                row += 1
