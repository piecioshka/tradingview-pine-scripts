//@version=6
indicator('Histogram Rozpiętości MA', shorttitle='HRMA', overlay=false)

aLen = input(50, 'Długość', group='Krótki')
aType = input.string(title='Typ', options=['SMA', 'EMA', 'WMA', 'VWMA', 'RMA'], group='Krótki', defval='SMA')
aSeries = switch aType
    'SMA' => ta.sma(close, aLen)
    'EMA' => ta.ema(close, aLen)
    'WMA' => ta.wma(close, aLen)
    'VWMA' => ta.vwma(close, aLen)
    'RMA' => ta.rma(close, aLen)
    => na

bLen = input(200, 'Długość', group='Długi')
bType = input.string(title='Typ', options=['SMA', 'EMA', 'WMA', 'VWMA', 'RMA'], group='Długi', defval='SMA')
bSeries = switch bType
    'SMA' => ta.sma(close, bLen)
    'EMA' => ta.ema(close, bLen)
    'WMA' => ta.wma(close, bLen)
    'VWMA' => ta.vwma(close, bLen)
    'RMA' => ta.rma(close, bLen)
    => na

histogram = aSeries - bSeries
histColor = histogram >= 0 ? histogram > histogram[1] ? color.new(color.green, 50) : color.new(color.green, 80) : histogram < histogram[1] ? color.new(color.red, 50) : color.new(color.red, 80)

plot(histogram, 'Histogram', color=histColor, linewidth=2, style=plot.style_columns)
hline(0, 'Zero', color=color.gray, linestyle=hline.style_solid)

// Krótka przebija długą w GÓRĘ (histogram przechodzi nad zero) -> impuls byczy -> BUY OPEN.
if (ta.crossover(aSeries, bSeries))
    line.new(bar_index, histogram, bar_index, histogram, color=color.new(color.green, 70), style=line.style_dashed, extend=extend.left)
    line.new(bar_index, high, bar_index, low, color=color.new(color.green, 70), style=line.style_dashed, extend=extend.right, force_overlay=true)
    label.new(bar_index, 0, 'BUY OPEN', color=color.new(color.green, 50), style=label.style_label_up, size=size.normal)

// Krótka przebija długą w DÓŁ (histogram przechodzi pod zero) -> impuls niedźwiedzi -> BUY CLOSE.
if (ta.crossunder(aSeries, bSeries))
    line.new(bar_index, histogram, bar_index, histogram, color=color.new(color.red, 70), style=line.style_dashed, extend=extend.left)
    line.new(bar_index, high, bar_index, low, color=color.new(color.red, 70), style=line.style_dashed, extend=extend.right, force_overlay=true)
    label.new(bar_index, 0, 'BUY CLOSE', color=color.new(color.red, 50), style=label.style_label_down, size=size.normal)
